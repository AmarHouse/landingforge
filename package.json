{
  "name": "landingforge",
  "version": "0.2.0",
  "description": "Local AI-powered website generator. Configure your own OpenAI-compatible endpoint and generate landing pages.",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "cf:build": "next build",
    "cf:preview": "next build && npx wrangler pages dev out/",
    "cf:deploy": "next build && npx wrangler pages deploy out/ --project-name=landingforge"
  },
